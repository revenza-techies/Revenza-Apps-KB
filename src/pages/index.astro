---
import GitBookDocsLayout from '../layouts/GitBookDocsLayout.astro';
import homeSidebarData from '../data/homeSidebar.json';
import * as homeDoc from '../../docs/revenza-home/README.mdx';

const {Content, frontmatter = {}} = homeDoc;
let headings = [];
if (typeof homeDoc.getHeadings === 'function') {
  headings = await homeDoc.getHeadings();
}
---

<GitBookDocsLayout
  sidebarData={homeSidebarData.homeSidebar || []}
  section="home"
  pathname="/"
  title={frontmatter.title || 'Revenza Docs'}
  description={frontmatter.description || 'Revenza documentation'}
  headings={headings}>
  <Content />
</GitBookDocsLayout>
